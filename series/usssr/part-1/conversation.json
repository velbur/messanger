{
  "contactName": "Даня",
  "contactStatus": "в сети",
  "myName": "Алиса",
  "wallpaper": "default",
  "messages": [
    {
      "author": "them",
      "sentAt": "18:12",
      "text": "Привет."
    },
    {
      "author": "them",
      "sentAt": "18:12",
      "text": "Ты меня видишь?"
    },
    {
      "author": "me",
      "sentAt": "18:12",
      "text": "Кого?"
    },
    {
      "author": "them",
      "sentAt": "18:12",
      "text": "Сообщение дошло?"
    },
    {
      "author": "me",
      "sentAt": "18:12",
      "text": "Раз я отвечаю — дошло."
    },
    {
      "author": "me",
      "sentAt": "18:12",
      "text": "Ты кто?"
    },
    {
      "author": "them",
      "sentAt": "18:12",
      "text": "Даня."
    },
    {
      "author": "them",
      "sentAt": "18:12",
      "text": "Не блокируй, пожалуйста."
    },
    {
      "author": "me",
      "sentAt": "18:12",
      "text": "Звучит как причина заблокировать 🙃"
    },
    {
      "author": "them",
      "sentAt": "18:12",
      "text": "Понимаю."
    },
    {
      "author": "them",
      "sentAt": "18:12",
      "text": "Но мне больше некому написать."
    },
    {
      "author": "me",
      "sentAt": "18:12",
      "text": "Откуда мой номер?"
    },
    {
      "author": "them",
      "sentAt": "18:12",
      "text": "Не знаю."
    },
    {
      "author": "them",
      "sentAt": "18:12",
      "text": "В телефоне открылся только этот чат."
    },
    {
      "author": "them",
      "sentAt": "18:12",
      "text": "Контактов нет. Сети нет. Интернета нет."
    },
    {
      "author": "me",
      "sentAt": "18:12",
      "text": "Подожди."
    },
    {
      "author": "me",
      "sentAt": "18:12",
      "text": "Сети нет, а мне сообщения доходят?"
    },
    {
      "author": "them",
      "sentAt": "18:12",
      "text": "И я не понимаю, как это работает."
    },
    {
      "author": "me",
      "sentAt": "18:12",
      "text": "Ладно, допустим."
    },
    {
      "author": "me",
      "sentAt": "18:12",
      "text": "В каком городе?"
    },
    {
      "author": "them",
      "sentAt": "18:12",
      "text": "Не знаю, честно. Я в полном шоке."
    },
    {
      "author": "them",
      "sentAt": "18:12",
      "text": "Я в каком-то маленьком городе."
    },
    {
      "author": "them",
      "sentAt": "18:12",
      "text": "Не Москва."
    },
    {
      "author": "me",
      "sentAt": "18:12",
      "text": "Очень мило, прям шпионский детектив 🕵️"
    },
    {
      "author": "them",
      "sentAt": "18:12",
      "text": "Вчера лег спать дома."
    },
    {
      "author": "them",
      "sentAt": "18:12",
      "text": "Проснулся на скамейке у какого-то гастронома."
    },
    {
      "author": "them",
      "sentAt": "18:12",
      "text": "Вокруг «Жигули», авоськи, вывеска «Молоко-овощи»."
    },
    {
      "author": "them",
      "sentAt": "18:12",
      "text": "И календарь на стене — 1984 год."
    },
    {
      "author": "me",
      "sentAt": "18:12",
      "text": "1984?"
    },
    {
      "author": "them",
      "sentAt": "18:12",
      "text": "Да."
    },
    {
      "author": "me",
      "sentAt": "18:12",
      "text": "Ты серьезно?"
    },
    {
      "author": "them",
      "sentAt": "18:12",
      "text": "Я бы не писал незнакомке, если бы все было нормально."
    },
    {
      "author": "me",
      "sentAt": "18:12",
      "text": "Люди пишут незнакомкам и когда все нормально."
    },
    {
      "author": "me",
      "sentAt": "18:12",
      "text": "Ты на съемках?"
    },
    {
      "author": "them",
      "sentAt": "18:12",
      "text": "Я бы очень хотел, чтобы это были съемки."
    },
    {
      "author": "me",
      "sentAt": "18:12",
      "text": "Или ты просто решил поиграть в попаданца?"
    },
    {
      "author": "them",
      "sentAt": "18:12",
      "text": "Я не играю."
    },
    {
      "author": "them",
      "sentAt": "18:12",
      "text": "Я стою у магазина, голодный, и не понимаю, чем тут платят."
    },
    {
      "author": "me",
      "sentAt": "18:12",
      "text": "Звучит как очень длинный пранк 😐"
    },
    {
      "author": "them",
      "sentAt": "18:12",
      "text": "У меня нет на это сил."
    },
    {
      "author": "them",
      "sentAt": "18:12",
      "text": "Я с утра ничего нормального не ел."
    },
    {
      "author": "me",
      "sentAt": "18:12",
      "text": "Ладно."
    },
    {
      "author": "me",
      "sentAt": "18:12",
      "text": "Допустим, ты не шутишь про голод."
    },
    {
      "author": "me",
      "sentAt": "18:12",
      "text": "Ты серьёзно думаешь, что я дура и поверю в 1984?"
    },
    {
      "author": "them",
      "sentAt": "18:12",
      "text": "Я и сам не верю."
    },
    {
      "author": "me",
      "sentAt": "18:12",
      "text": "Тогда зачем мне это пишешь?"
    },
    {
      "author": "them",
      "sentAt": "18:12",
      "text": "Потому что больше некому."
    },
    {
      "author": "them",
      "sentAt": "18:12",
      "text": "И потому что ты отвечаешь."
    },
    {
      "author": "me",
      "sentAt": "18:12",
      "text": "…"
    },
    {
      "author": "them",
      "sentAt": "18:12",
      "text": "Могу отправить фото."
    },
    {
      "author": "them",
      "sentAt": "18:12",
      "text": "Не «доказательство времени»."
    },
    {
      "author": "them",
      "sentAt": "18:12",
      "text": "Просто где я сейчас."
    },
    {
      "author": "me",
      "sentAt": "18:12",
      "text": "Отправляй 📸"
    },
    {
      "author": "me",
      "sentAt": "18:12",
      "text": "Но если это декорации — я сразу пойму."
    },
    {
      "author": "them",
      "sentAt": "18:16",
      "imagePrompt": "витрина гастронома. За стеклом — бутылки молока в бумажных пакетах, крупы в банках, ценники на картонке. На стене висит отрывной календарь с датой «14 октября 1984»."
    },
    {
      "author": "me",
      "sentAt": "18:16",
      "text": "Похоже на старый магазин."
    },
    {
      "author": "me",
      "sentAt": "18:16",
      "text": "Но одной фоткой ты меня не купишь."
    },
    {
      "author": "them",
      "sentAt": "18:16",
      "text": "Я так и понял."
    },
    {
      "author": "them",
      "sentAt": "18:16",
      "imagePrompt": "газета «Советская Россия», свернутая трубочкой. На первой полосе видна дата: 14 октября 1984 года."
    },
    {
      "author": "me",
      "sentAt": "18:16",
      "text": "Газету можно купить или где-то взять 🙂"
    },
    {
      "author": "them",
      "sentAt": "18:16",
      "text": "Зачем мне покупать газету, если я голодный?"
    },
    {
      "author": "me",
      "sentAt": "18:16",
      "text": "Зачем мне верить незнакомцу с «советской» газетой?"
    },
    {
      "author": "them",
      "sentAt": "18:16",
      "text": "Не знаю."
    },
    {
      "author": "them",
      "sentAt": "18:16",
      "text": "Но я правда голодный, а на что купить еду — понятия не имею."
    },
    {
      "author": "me",
      "sentAt": "18:16",
      "text": "…"
    },
    {
      "author": "me",
      "sentAt": "18:16",
      "text": "Окей, это всё ещё может быть реквизит."
    },
    {
      "author": "me",
      "sentAt": "18:16",
      "text": "Но голод выглядит настоящим."
    },
    {
      "author": "me",
      "sentAt": "18:16",
      "text": "Ладно."
    },
    {
      "author": "me",
      "sentAt": "18:16",
      "text": "Про 1984 я все еще не верю."
    },
    {
      "author": "me",
      "sentAt": "18:16",
      "text": "Я сейчас просто играю в эту игру ради развлечения."
    },
    {
      "author": "me",
      "sentAt": "18:16",
      "text": "Но за идиотку меня не держи."
    },
    {
      "author": "me",
      "sentAt": "18:16",
      "text": "Я Алиса, если что."
    },
    {
      "author": "me",
      "sentAt": "18:16",
      "text": "Но раз ты голодный — давай сначала с этим."
    },
    {
      "author": "me",
      "sentAt": "18:16",
      "text": "Что у тебя в карманах?"
    },
    {
      "author": "them",
      "sentAt": "18:16",
      "text": "Ключи от квартиры 2026 года."
    },
    {
      "author": "them",
      "sentAt": "18:16",
      "text": "Карта «Тройка»."
    },
    {
      "author": "them",
      "sentAt": "18:16",
      "text": "Тысяча рублей."
    },
    {
      "author": "them",
      "sentAt": "18:16",
      "text": "Один батончик Snickers."
    },
    {
      "author": "them",
      "sentAt": "18:16",
      "text": "Батончик уже съел."
    },
    {
      "author": "me",
      "sentAt": "18:16",
      "text": "Поздравляю 🥲"
    },
    {
      "author": "me",
      "sentAt": "18:16",
      "text": "В СССР ты богат примерно ничем."
    },
    {
      "author": "them",
      "sentAt": "18:16",
      "text": "Можно без исторического унижения?"
    },
    {
      "author": "me",
      "sentAt": "18:16",
      "text": "Нет 😌"
    },
    {
      "author": "me",
      "sentAt": "18:16",
      "text": "Это часть опыта."
    },
    {
      "author": "them",
      "sentAt": "18:16",
      "text": "Я стою у гастронома."
    },
    {
      "author": "them",
      "sentAt": "18:16",
      "text": "Очередь."
    },
    {
      "author": "them",
      "sentAt": "18:16",
      "text": "Люди смотрят на мои кроссовки."
    },
    {
      "author": "me",
      "sentAt": "18:16",
      "text": "Потому что ты в кроссовках?"
    },
    {
      "author": "them",
      "sentAt": "18:16",
      "text": "И в худи."
    },
    {
      "author": "them",
      "sentAt": "18:16",
      "text": "И вообще я выгляжу как пришелец из другого времени."
    },
    {
      "author": "me",
      "sentAt": "18:16",
      "text": "Технически так и есть 😬"
    },
    {
      "author": "me",
      "sentAt": "18:16",
      "text": "Только не говори им это."
    },
    {
      "author": "them",
      "sentAt": "18:22",
      "text": "Что мне делать?"
    },
    {
      "author": "me",
      "sentAt": "18:22",
      "text": "Зайди в гастроном."
    },
    {
      "author": "me",
      "sentAt": "18:22",
      "text": "Посмотри, что продают."
    },
    {
      "author": "me",
      "sentAt": "18:22",
      "text": "Сфоткай ценники."
    },
    {
      "author": "them",
      "sentAt": "18:22",
      "text": "Зачем?"
    },
    {
      "author": "me",
      "sentAt": "18:22",
      "text": "Чтобы я поняла, на что ты можешь рассчитывать."
    },
    {
      "author": "me",
      "sentAt": "18:22",
      "text": "Если это вообще не пранк."
    },
    {
      "author": "them",
      "sentAt": "18:22",
      "imagePrompt": "ценник на хлеб «Бородинский» — 20 коп. Кефир — 28 коп. Пирожок с капустой — 15 коп."
    },
    {
      "author": "me",
      "sentAt": "18:22",
      "text": "Окей."
    },
    {
      "author": "me",
      "sentAt": "18:22",
      "text": "Цены правдоподобные."
    },
    {
      "author": "them",
      "sentAt": "18:22",
      "text": "Ты знаешь цены 1984 года?"
    },
    {
      "author": "me",
      "sentAt": "18:22",
      "text": "Гуглю 🕵️‍♀️"
    },
    {
      "author": "me",
      "sentAt": "18:22",
      "text": "Не думай, что я специалист."
    },
    {
      "author": "them",
      "sentAt": "18:22",
      "text": "И что?"
    },
    {
      "author": "me",
      "sentAt": "18:22",
      "text": "Хлеб — 20 копеек."
    },
    {
      "author": "me",
      "sentAt": "18:22",
      "text": "Кефир — 28."
    },
    {
      "author": "me",
      "sentAt": "18:22",
      "text": "Пирожок — 15."
    },
    {
      "author": "me",
      "sentAt": "18:22",
      "text": "Итого 63 копейки на минимальный ужин."
    },
    {
      "author": "them",
      "sentAt": "18:22",
      "text": "У меня тысяча рублей 2026 года."
    },
    {
      "author": "me",
      "sentAt": "18:22",
      "text": "У продавца будут вопросы."
    },
    {
      "author": "them",
      "sentAt": "18:22",
      "text": "Я уже понял."
    },
    {
      "author": "me",
      "sentAt": "18:22",
      "text": "Есть что-нибудь, что можно обменять?"
    },
    {
      "author": "them",
      "sentAt": "18:22",
      "text": "Ключи бесполезны."
    },
    {
      "author": "them",
      "sentAt": "18:22",
      "text": "Карта «Тройка» — тоже."
    },
    {
      "author": "them",
      "sentAt": "18:22",
      "text": "Остались наушники."
    },
    {
      "author": "them",
      "sentAt": "18:22",
      "text": "Один наушник. Второй потерял еще утром."
    },
    {
      "author": "me",
      "sentAt": "18:22",
      "text": "Один наушник — это грустно и бесполезно 😔"
    },
    {
      "author": "them",
      "sentAt": "18:22",
      "text": "Спасибо за поддержку."
    },
    {
      "author": "me",
      "sentAt": "18:31",
      "text": "Ладно."
    },
    {
      "author": "me",
      "sentAt": "18:31",
      "text": "Телефон никому не показывай."
    },
    {
      "author": "me",
      "sentAt": "18:31",
      "text": "Вообще никому."
    },
    {
      "author": "me",
      "sentAt": "18:31",
      "text": "Наушник тоже лучше не доставать."
    },
    {
      "author": "me",
      "sentAt": "18:31",
      "text": "Попробуй не выменять, а попросить по-человечески."
    },
    {
      "author": "me",
      "sentAt": "18:31",
      "text": "Осторожно."
    },
    {
      "author": "me",
      "sentAt": "18:31",
      "text": "Не «я из будущего»."
    },
    {
      "author": "me",
      "sentAt": "18:31",
      "text": "Просто «потерял кошелек, помогите»."
    },
    {
      "author": "them",
      "sentAt": "18:31",
      "text": "Это стыдно."
    },
    {
      "author": "me",
      "sentAt": "18:31",
      "text": "Зато не будешь голодать."
    },
    {
      "author": "them",
      "sentAt": "18:31",
      "text": "Справедливо."
    },
    {
      "author": "me",
      "sentAt": "18:31",
      "text": "Действуй."
    },
    {
      "author": "them",
      "sentAt": "18:31",
      "text": "Сейчас попробую."
    },
    {
      "author": "them",
      "sentAt": "18:38",
      "text": "Стою в очереди."
    },
    {
      "author": "them",
      "sentAt": "18:38",
      "text": "Передо мной бабушка."
    },
    {
      "author": "them",
      "sentAt": "18:38",
      "text": "Она обернулась и спросила, почему я так странно одет."
    },
    {
      "author": "me",
      "sentAt": "18:38",
      "text": "Что ответил?"
    },
    {
      "author": "them",
      "sentAt": "18:38",
      "text": "Сказал, что приехал из другого города."
    },
    {
      "author": "them",
      "sentAt": "18:38",
      "text": "И что кошелек потерял."
    },
    {
      "author": "me",
      "sentAt": "18:38",
      "text": "Неплохо 👌"
    },
    {
      "author": "them",
      "sentAt": "18:38",
      "text": "Она сказала: «Видно» и дала мне рубль."
    },
    {
      "author": "me",
      "sentAt": "18:38",
      "text": "Серьезно? 😳"
    },
    {
      "author": "them",
      "sentAt": "18:38",
      "text": "Серьезно."
    },
    {
      "author": "them",
      "sentAt": "18:38",
      "text": "Сказала: «На ужин. И куртку нормальную где-нибудь найди, замёрзнешь»."
    },
    {
      "author": "me",
      "sentAt": "18:38",
      "text": "…"
    },
    {
      "author": "them",
      "sentAt": "18:38",
      "text": "Что?"
    },
    {
      "author": "me",
      "sentAt": "18:38",
      "text": "Ничего."
    },
    {
      "author": "me",
      "sentAt": "18:38",
      "text": "Продолжай."
    },
    {
      "author": "them",
      "sentAt": "18:44",
      "text": "Я купил."
    },
    {
      "author": "them",
      "sentAt": "18:44",
      "text": "Бородинский."
    },
    {
      "author": "them",
      "sentAt": "18:44",
      "text": "Кефир."
    },
    {
      "author": "them",
      "sentAt": "18:44",
      "text": "Пирожок."
    },
    {
      "author": "me",
      "sentAt": "18:44",
      "text": "Сфоткай 📸"
    },
    {
      "author": "them",
      "sentAt": "18:44",
      "imagePrompt": "бумажный пакет с хлебом, бутылка кефира, пирожок на ладони. На заднем плане — вечерний гастроном и тусклый фонарь."
    },
    {
      "author": "me",
      "sentAt": "18:44",
      "text": "Выглядит… нормально 🙂"
    },
    {
      "author": "them",
      "sentAt": "18:44",
      "text": "Это и есть нормально."
    },
    {
      "author": "them",
      "sentAt": "18:44",
      "text": "Я ем на скамейке."
    },
    {
      "author": "me",
      "sentAt": "18:44",
      "text": "Как?"
    },
    {
      "author": "them",
      "sentAt": "18:44",
      "text": "Хлеб — нормальный."
    },
    {
      "author": "them",
      "sentAt": "18:44",
      "text": "Кефир — другой."
    },
    {
      "author": "them",
      "sentAt": "18:44",
      "text": "Пирожок — лучший в моей жизни."
    },
    {
      "author": "me",
      "sentAt": "18:44",
      "text": "Ты съел один пирожок и это лучший в твоей жизни? 😄"
