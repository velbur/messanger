# OpenRouter — диалоги (ChatGPT) и картинки; обязателен для генерации текста и изображений
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TEXT_MODEL=openai/gpt-5.4
OPENROUTER_IMAGE_MODEL=openai/gpt-5.4-image-2
OPENROUTER_TTS_MODEL=google/gemini-3.1-flash-tts-preview
OPENROUTER_TTS_VOICE_FEMALE=Leda
OPENROUTER_TTS_VOICE_MALE=Puck
OPENROUTER_VIDEO_MODEL=google/veo-3.1-lite
# Разрешение story-видео: 720p или 1080p (по умолчанию 1080p)
OPENROUTER_VIDEO_RESOLUTION=1080p
# Публичный HTTPS URL UI (опционально; иначе картинки уходят в OpenRouter как data URL)
PUBLIC_BASE_URL=
OPENROUTER_IMAGE_ASPECT_RATIO=4:3
OPENROUTER_IMAGE_SIZE=1K
OPENROUTER_APP_NAME=messanger

# Depth parallax: auto (V2 в .venv на Mac) | depth-v2 | xenova (Docker CPU)
# Нативный воркер: ./run.sh setup-native && ./run.sh worker-native
# STORY_DEPTH_PROVIDER=auto
# STORY_DEPTH_V2_MODEL=depth-anything/Depth-Anything-V2-Large-hf

# YouTube — автозагрузка Shorts (refresh token через OAuth Playground)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
